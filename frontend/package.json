{
  "name": "lumentix-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "check-deps": "node -e \"const p=require('./package.json'); const shared=Object.keys(p.dependencies||{}).filter(k=>p.devDependencies?.[k]); if(shared.length){console.error('Duplicate deps:',shared);process.exit(1)}\""
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@stellar/freighter-api": "^6.0.1",
    "@stellar/stellar-sdk": "^11.2.2",
    "next": "^14.2.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.71.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.14.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.5",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.40",
    "tailwindcss": "^3.4.7",
    "typescript": "^5.5.4",
    "vitest": "^4.1.7",
    "jest-axe": "^9.0.0",
    "@axe-core/react": "^4.10.0"
  }
}
